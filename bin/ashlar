#!/usr/bin/env python3
"""Ashlar — track token savings from context compaction."""
import argparse
import json
import time
from pathlib import Path

LEDGER_DIR = Path.home() / ".ashlar"
LEDGER_PATH = LEDGER_DIR / "ledger.jsonl"


def cmd_record(args):
    LEDGER_DIR.mkdir(parents=True, exist_ok=True)
    entry = {
        "ts": time.time(),
        "before": args.before,
        "after": args.after,
        "label": args.label or "",
    }
    with LEDGER_PATH.open("a") as f:
        f.write(json.dumps(entry) + "\n")
    saved = args.before - args.after
    pct = (saved / args.before * 100) if args.before else 0
    print(f"Recorded: {args.before} -> {args.after} tokens ({pct:.0f}% cut)")


def cmd_report(_args):
    if not LEDGER_PATH.exists():
        print("No stones dressed yet. Run `ashlar record` first.")
        return
    total_before = total_after = count = 0
    with LEDGER_PATH.open() as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            entry = json.loads(line)
            total_before += entry["before"]
            total_after += entry["after"]
            count += 1
    saved = total_before - total_after
    pct = (saved / total_before * 100) if total_before else 0
    print(f"Stones dressed:   {count}")
    print(f"Rough weight:     {total_before:,} tokens")
    print(f"Perfect weight:   {total_after:,} tokens")
    print(f"Waste removed:    {saved:,} tokens ({pct:.0f}%)")


def main():
    parser = argparse.ArgumentParser(prog="ashlar")
    sub = parser.add_subparsers(dest="command", required=True)

    p_record = sub.add_parser("record", help="record a compaction result")
    p_record.add_argument("--before", type=int, required=True)
    p_record.add_argument("--after", type=int, required=True)
    p_record.add_argument("--label", type=str, default=None)
    p_record.set_defaults(func=cmd_record)

    p_report = sub.add_parser("report", help="show cumulative savings")
    p_report.set_defaults(func=cmd_report)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
